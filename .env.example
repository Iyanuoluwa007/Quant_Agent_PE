# Quant Agent v2.1 -- Public Edition
# Copy to .env and fill in your keys

# -- Broker Mode --
# "simulated" (default, no keys needed) or "alpaca"
BROKER=simulated
INITIAL_CAPITAL=100000

# -- Virtual Capital --
# Agent manages a virtual allocation WITHIN the broker account.
# Alpaca paper may have $20K but agent only trades with its slice.
VIRTUAL_CAPITAL_ENABLED=true
VIRTUAL_INITIAL_CAPITAL=12500
VIRTUAL_MONTHLY_DEPOSIT=625
VIRTUAL_DEPOSIT_DAY=1

# -- Alpaca (only needed if BROKER=alpaca) --
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_ENV=paper

# -- Anthropic Claude API --
ANTHROPIC_API_KEY=your_anthropic_key
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# -- Currency --
CURRENCY=USD
CURRENCY_SYMBOL=$

# -- Market Hours Gate --
MARKET_HOURS_ONLY=true
PRE_MARKET_BUFFER_MIN=30

# -- Kill Switch --
KILL_SWITCH_DRAWDOWN_PCT=20.0

# -- Volatility Targeting --
VOL_TARGET_PCT=12.0

# -- Dashboard --
DASHBOARD_TOKEN=your_random_secret_token

# -- Email Notifications (optional) --
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=yourbot@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=you@email.com

# -- Optional Overrides --
# FORCE_SHORT_PCT=0
# FORCE_MID_PCT=0
# FORCE_LONG_PCT=0
# LOG_LEVEL=INFO
